# Backup diário do Postgres do remix-songs (Fase 9 da migração)
# Instalar na VPS:
#   sudo cp /opt/remix-songs/ops/cron/remix-backup /etc/cron.d/remix-backup
#   sudo chmod 0644 /etc/cron.d/remix-backup
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# m h dom mon dow user  command
0 3 * * * root /opt/remix-songs/scripts/backup.sh >> /var/log/remix-backup.log 2>&1
