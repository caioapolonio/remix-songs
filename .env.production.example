# Template do ambiente de produção (docker-compose.prod.yml).
# Copie para `.env.prod` (local, validação) ou `.env.production` (VPS) e preencha.
# O compose lê via: docker compose -f docker-compose.prod.yml --env-file .env.prod ...

# ============ Caddy ============
# Local (validação):  :80
# VPS (produção):      remix-songs.com
SITE_ADDRESS=:80

# ============ Postgres ============
# Senha do Postgres em container (use uma forte na VPS).
POSTGRES_PASSWORD=postgres

# ============ better-auth ============
# Gere com: openssl rand -hex 32
BETTER_AUTH_SECRET=
# Origem pública da app. Local: http://localhost  | VPS: https://remix-songs.com
# (Usado como BETTER_AUTH_URL e como NEXT_PUBLIC_APP_URL no build.)
NEXT_PUBLIC_APP_URL=http://localhost

# ============ Resend ============
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# ============ Stripe ============
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_ID=
