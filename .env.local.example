# ============ Database ============
# Local dev: aponta para o Postgres do docker-compose.dev.yml (porta 5434)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5434/remix

# ============ better-auth ============
# Gere com: openssl rand -hex 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ============ Resend ============
# https://resend.com/api-keys
RESEND_API_KEY=
# Endereço "from" — em dev pode usar onboarding@resend.dev sem verificar domínio
RESEND_FROM=onboarding@resend.dev

# ============ Stripe ============
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_ID=

# ============ App ============
NEXT_PUBLIC_APP_URL=http://localhost:3000
